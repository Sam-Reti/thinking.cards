rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasAll(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnly(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ── Categories ────────────────────────────────────────────────────
    match /categories/{categoryId} {
      allow read: if true;

      allow create: if isAdmin()
        && hasAll(['name', 'description', 'color', 'order'])
        && hasOnly(['name', 'description', 'color', 'order', 'type'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 100
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 500
        && request.resource.data.color is string
        && request.resource.data.color.matches('^#[0-9A-Fa-f]{6}$')
        && request.resource.data.order is int
        && (!('type' in request.resource.data) || request.resource.data.type in ['standard', 'quiz', 'matrix']);

      allow update: if isAdmin()
        && hasOnly(['name', 'description', 'color', 'order', 'type'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 100
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 500
        && request.resource.data.color is string
        && request.resource.data.color.matches('^#[0-9A-Fa-f]{6}$')
        && request.resource.data.order is int
        && (!('type' in request.resource.data) || request.resource.data.type in ['standard', 'quiz', 'matrix']);

      allow delete: if isAdmin();
    }

    // ── Cards ─────────────────────────────────────────────────────────
    match /cards/{cardId} {
      allow read: if isAuthenticated();

      allow create: if isAdmin()
        && hasAll(['questionText', 'categoryId', 'cardNumber'])
        && hasOnly(['questionText', 'categoryId', 'cardNumber', 'options', 'correctIndex', 'explanation', 'matrixGroups', 'matrixClues', 'matrixSolution', 'matrixScenario', 'matrixExplanation'])
        && request.resource.data.questionText is string
        && request.resource.data.questionText.size() > 0
        && request.resource.data.questionText.size() <= 2000
        && request.resource.data.categoryId is string
        && request.resource.data.categoryId.size() > 0
        && request.resource.data.cardNumber is int
        && request.resource.data.cardNumber > 0
        && (!('options' in request.resource.data) || request.resource.data.options is list)
        && (!('correctIndex' in request.resource.data) || request.resource.data.correctIndex is int)
        && (!('explanation' in request.resource.data) || request.resource.data.explanation is string);

      allow update: if isAdmin()
        && hasOnly(['questionText', 'categoryId', 'cardNumber', 'options', 'correctIndex', 'explanation', 'matrixGroups', 'matrixClues', 'matrixSolution', 'matrixScenario', 'matrixExplanation'])
        && request.resource.data.questionText is string
        && request.resource.data.questionText.size() > 0
        && request.resource.data.questionText.size() <= 2000
        && request.resource.data.categoryId is string
        && request.resource.data.categoryId.size() > 0
        && request.resource.data.cardNumber is int
        && request.resource.data.cardNumber > 0
        && (!('options' in request.resource.data) || request.resource.data.options is list)
        && (!('correctIndex' in request.resource.data) || request.resource.data.correctIndex is int)
        && (!('explanation' in request.resource.data) || request.resource.data.explanation is string);

      allow delete: if isAdmin();
    }

    // ── Users ────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);

      allow create: if isOwner(userId)
        && hasAll(['email', 'createdAt'])
        && hasOnly(['email', 'createdAt'])
        && request.resource.data.email is string
        && request.resource.data.createdAt is string;

      allow update: if isOwner(userId)
        && hasOnly(['email', 'createdAt'])
        && request.resource.data.email is string
        && request.resource.data.createdAt is string;

      allow delete: if false;
    }

    // ── Favorites ─────────────────────────────────────────────────────
    match /users/{userId}/favorites/{cardId} {
      allow read: if isOwner(userId);

      allow create: if isOwner(userId)
        && hasAll(['addedAt'])
        && hasOnly(['addedAt'])
        && request.resource.data.addedAt is timestamp;

      allow update: if false;
      allow delete: if isOwner(userId);
    }

    // ── Activity (streak tracking) ─────────────────────────────────────
    match /users/{userId}/activity/{dateKey} {
      allow read: if isOwner(userId);

      allow create: if isOwner(userId)
        && hasAll(['lastActiveAt'])
        && hasOnly(['lastActiveAt'])
        && request.resource.data.lastActiveAt is timestamp;

      allow update: if isOwner(userId)
        && hasOnly(['lastActiveAt'])
        && request.resource.data.lastActiveAt is timestamp;

      allow delete: if isOwner(userId);
    }

    // ── Progress ──────────────────────────────────────────────────────
    match /users/{userId}/progress/{cardId} {
      allow read: if isOwner(userId);

      allow create: if isOwner(userId)
        && hasAll(['seenAt'])
        && hasOnly(['seenAt'])
        && request.resource.data.seenAt is timestamp;

      allow update: if false;
      allow delete: if isOwner(userId);
    }

    // ── Card State (card position) ──────────────────────────────────
    match /users/{userId}/cardState/{categoryId} {
      allow read, write: if isOwner(userId);
    }

    // ── Quiz State (quiz progress) ──────────────────────────────────
    match /users/{userId}/quizState/{categoryId} {
      allow read, write: if isOwner(userId);
    }

    // ── Matrix State (puzzle progress) ──────────────────────────────
    match /users/{userId}/matrixState/{categoryId} {
      allow read, write: if isOwner(userId);
    }

    // ── Catch-all deny ────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
